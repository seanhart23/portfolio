        <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0-alpha.6/css/bootstrap.min.css" integrity="sha384-rwoIResjU2yc3z8GV/NPeZWAv56rSmLldC3R/AZzGRnGxQQKnKkoFVhFQhNUwEyJ" crossorigin="anonymous">        
        <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.3.1/jquery.min.js"></script>
        <link href="https://fonts.googleapis.com/css?family=Lato:300" rel="stylesheet">
        <link href="https://stackpath.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet">
        <meta name = "viewport" content = "width=device-width">
    </head>
<body>
    
<div id='mainBanner'>
    <nav class="navbar navbar-toggleable-md navbar-inverse">
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" href="#mainBanner">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#portfolio">Portfolio</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#contact">Contact</a>
                </li>
            </ul>
        </div>
    </nav>
    
    <div class='container header'>
        <div class='row header top'>
            <div class='col-lg-6' id='left-header'>
                <div id='header-name'>Sean Hart</div>
                <div id='header-summary'>Front End Web Developer</div>
                <div id='header-description'>I am a web developer with passion 
                for simple and usable design. 
                A good design should carry a message that is 
                clear and intuitive. That begins with clear 
                and open communication with my clients.</div>
                <div class='row' id='icon-row'>
                    <div class='col-lg-4 col-xs-4 icon'><i class="fa fa-cogs" style='font-size:40px'></i><br>Customized<br>Websites</div>
                    <div class='col-lg-4 col-xs-4 icon'><i class="fa fa-mobile-phone" style='font-size:40px'></i><br>Responsive<br>Design</div>
                    <div class='col-lg-4 col-xs-4 icon'><i class="fa fa-check" style='font-size:40px'></i><br>Clean<br>& Simple</div>
                </div>
            </div> 
            <div class='col-lg-1'></div>
            <div class='col-lg-4'>
                <div id='image-container'></div>
            </div>
        </div>
        <div class='row down'>
            <div class'col-lg-12' id='down-image'>
                <a href="#portfolio"><img src='./images/downarrow.png'></a>
            </div>
        </div>
    </div>
</div>

<div class='container header' id='portfolio'>
    <div class='row header-alt'>
        <div class='col-lg-6' id='left-header'>
            <div class='header-name-alt'>Portfolio</div>
            <div id='header-summary'>Latest Projects</div>
            <div class='header-description-alt'>CSS, HTML, Javascript, NODE</div>
        </div> 
        <div class='col-lg-1'></div>
        <div class='col-lg-4'>
            <div class='portfolio-item'><a href='https://morning-river-54820.herokuapp.com/' target='_blank'><img src='./images/mfp.jpg' class='portfolio-img'></a><span class='portfolio-description'>My Financial Planner - Web App</span></div>
            <div class='portfolio-item'><a href='http://www.harttohearts.com' target='_blank'><img src='./images/harttohearts.jpg' class='portfolio-img'></a><span class='portfolio-description'>Hart to Hearts - Blog</span></div>
        </div>
    </div>
</div>

<div class='container header' id='contact'>
    <div class='row header-alt-contact'>
        <div class='col-lg-6' id='left-header'>
            <div class='header-name-alt'>Contact</div>
            <div id='header-summary'>Contact Me Today</div>
            <div class='header-description-alt'></div>
        </div>
        <div class='col-lg-1'></div>
        <div class='col-lg-4'>
            <form action="/send-email" method="post">
                <div class="form-group">
                  <label for="name">Name:</label>
                  <input type="text" class="form-control textbox" name="name">
                </div>   
                <div class="form-group">
                  <label for="email">Email Address:</label>
                  <input type="email" class="form-control textbox" name="email">
                </div>
                <div class="form-group">
                  <label for="subject">Subject:</label>
                  <input type="text" class="form-control textbox" name="subject">
                </div>
                <div class="form-group">
                  <label for="body">Message:</label>
                  <textarea cols="5" rows="5"class="form-control" name="body"></textarea>
                </div>
                <div class="form-group">
                  <button type="submit" class="btn">Send</button>
                </div> 
            </form>
        </div>
    </div>
</div>
<div id='footer'>
   <div id='copyright'>Copyright &copy; 2018 Sean Hart - Freelance Web Developer</div> 
</div>
